<Window x:Class="Tetris.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tetris"
        WindowState="Maximized"
        WindowStyle="None"
        Background="#0F172A"
        KeyDown="Window_KeyDown">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="32" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="12"
                BorderBrush="#475569"
                BorderThickness="2"
                Background="#020617"
                Padding="8">
            <Canvas x:Name="GameCanvas"
                    Width="360"
                    Height="720" />
        </Border>

        <StackPanel Grid.Column="2" VerticalAlignment="Top">
            <TextBlock Text="TETRIS"
                       Foreground="#E2E8F0"
                       FontSize="44"
                       FontWeight="Bold"
                       Margin="0,0,0,20" />

            <Border CornerRadius="10" BorderBrush="#334155" BorderThickness="2" Background="#0B1224" Padding="16" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="WYNIK" Foreground="#94A3B8" FontSize="14" />
                    <TextBlock x:Name="ScoreText" Text="0" Foreground="#F8FAFC" FontSize="32" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border CornerRadius="10" BorderBrush="#334155" BorderThickness="2" Background="#0B1224" Padding="16" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="POZIOM" Foreground="#94A3B8" FontSize="14" />
                    <TextBlock x:Name="LevelText" Text="1" Foreground="#F8FAFC" FontSize="30" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border CornerRadius="10" BorderBrush="#334155" BorderThickness="2" Background="#0B1224" Padding="16" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="NASTĘPNY" Foreground="#94A3B8" FontSize="14" Margin="0,0,0,8" />
                    <Canvas x:Name="NextPieceCanvas" Width="120" Height="120" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusText"
                       Text="Strzałki: ruch/obrót • Spacja: zrzut • Esc: zamknij"
                       Foreground="#94A3B8"
                       TextWrapping="Wrap"
                       FontSize="15"
                       MaxWidth="260"
                       Margin="0,6,0,0" />
        </StackPanel>
    </Grid>
</Window>
